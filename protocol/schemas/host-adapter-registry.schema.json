{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Zaoqu-Liu/converge-skill/protocol/schemas/host-adapter-registry.schema.json",
  "title": "Converge Host Adapter Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "registry_version", "proof_tiers", "hosts"],
  "properties": {
    "protocol_version": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "registry_version": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "description": {
      "type": "string"
    },
    "proof_tiers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["H0", "H1", "H2", "H3", "H4"],
      "patternProperties": {
        "^H[0-4]$": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "evidence_required", "claim_allowed"],
          "properties": {
            "name": {"type": "string"},
            "evidence_required": {"type": "string"},
            "claim_allowed": {"type": "string"}
          }
        }
      }
    },
    "hosts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "host_id",
          "display_name",
          "source_anchor",
          "source_urls",
          "instruction_surfaces",
          "install",
          "interaction",
          "proof"
        ],
        "properties": {
          "host_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "display_name": {"type": "string"},
          "source_anchor": {"type": "string"},
          "source_urls": {
            "type": "array",
            "items": {"type": "string", "format": "uri"}
          },
          "instruction_surfaces": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "install": {
            "type": "object",
            "additionalProperties": false,
            "required": ["target_key", "copy_skill", "anchor_label", "anchors", "bridge_files"],
            "properties": {
              "target_key": {"type": ["string", "null"]},
              "copy_skill": {"type": "boolean"},
              "anchor_label": {"type": "string"},
              "anchors": {
                "type": "array",
                "items": {"type": "string"}
              },
              "bridge_files": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["path", "kind", "required_for_h1"],
                  "properties": {
                    "path": {"type": "string"},
                    "kind": {"type": "string"},
                    "required_for_h1": {"type": "boolean"}
                  }
                }
              }
            }
          },
          "interaction": {
            "type": "object",
            "additionalProperties": false,
            "required": ["native_question_surface", "native_question_tool", "fallback_surface"],
            "properties": {
              "native_question_surface": {"type": "string"},
              "native_question_tool": {"type": ["string", "null"]},
              "fallback_surface": {"type": "string"}
            }
          },
          "proof": {
            "type": "object",
            "additionalProperties": false,
            "required": ["current_claim", "eval_case", "h3_boundary"],
            "properties": {
              "current_claim": {"type": "string", "pattern": "^H[0-4]"},
              "eval_case": {"type": "string"},
              "h3_boundary": {"type": "string"}
            }
          }
        }
      }
    }
  }
}
