{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Zaoqu-Liu/converge-skill/protocol/schemas/host-capability.schema.json",
  "title": "Converge Host Capability Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "hosts"],
  "properties": {
    "protocol_version": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "hosts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "host_id",
          "display_name",
          "instruction_surface",
          "install_surface",
          "interaction_surface",
          "fallback_surface",
          "current_claim",
          "eval_case",
          "h3_boundary"
        ],
        "properties": {
          "host_id": {"type": "string"},
          "display_name": {"type": "string"},
          "instruction_surface": {"type": "string"},
          "install_surface": {"type": "string"},
          "interaction_surface": {"type": "string"},
          "fallback_surface": {"type": "string"},
          "current_claim": {
            "type": "string",
            "pattern": "^H[0-4]"
          },
          "eval_case": {"type": "string"},
          "h3_boundary": {"type": "string"}
        }
      }
    }
  }
}
