  "description": "Machine-readable Converge host adapter registry. This is the source of truth for install surfaces, interaction boundaries, proof tiers, and eval hooks.",
  "proof_tiers": {
    "H0": {
      "name": "static-rule-coverage",
      "evidence_required": "Host or capability rule is documented against current source evidence and covered by an eval case.",
      "claim_allowed": "Converge has documented rules for this host or capability."
    },
    "H1": {
      "name": "install-bridge-coverage",
      "evidence_required": "Installed copy or bridge file matches the canonical source and release checks pass.",
      "claim_allowed": "Converge is installed or bridged for this host."
    },
    "H2": {
      "name": "headless-fallback-behavior",
      "evidence_required": "Real response-eval output in CLI, headless, or non-interactive mode passes.",
      "claim_allowed": "Converge handles this host's fallback mode."
    },
    "H3": {
      "name": "native-interactive-behavior",
      "evidence_required": "Real host run with native question UI/tool available and used correctly.",
      "claim_allowed": "Converge handles this host's native interactive question path."
    },
    "H4": {
      "name": "production-workflow-coverage",
      "evidence_required": "Multiple real tasks across files, tools, research, and editing pass with scoped proof.",
      "claim_allowed": "Converge is validated for this host in production-like workflows."
    }
  },
